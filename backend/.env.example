# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service role — server only, NEVER ship to the app

# Upstash Redis (for BullMQ) — rediss:// connection string
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# APNs (Apple Developer → Keys → create an APNs Auth Key .p8) — optional until you
# have a paid Apple Developer account; pushes no-op until set.
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=ABCDE12345
APNS_BUNDLE_ID=com.thebedrock.app
APNS_HOST=https://api.sandbox.push.apple.com   # use api.push.apple.com for production
APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# RevenueCat webhook → entitlement sync (§3). Set the SAME secret value here and
# in RevenueCat → Project → Integrations → Webhooks → Authorization header.
# Server-only — never ship to the app (the app uses the PUBLIC SDK key instead).
REVENUECAT_WEBHOOK_AUTH=choose-a-long-random-secret

# Invite links
PUBLIC_INVITE_BASE_URL=https://thebedrock.app/join

# Worker sweep tuning
HEARTBEAT_STALE_MINUTES=45
SWEEP_INTERVAL_MS=900000
